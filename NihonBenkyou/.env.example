# ─── Frontend environment variables (Vite) ─────────────────────────
# All Vite env vars MUST be prefixed with VITE_ to be exposed to the client.

# Backend API base URL (no trailing slash).
# Local dev: leave unset to use the default http://localhost:3001/api
# Production (Vercel): https://api.angeliephl.dev/api
VITE_API_URL=http://localhost:3001/api

# Base path the app is served under. MUST end with a trailing slash if set.
# Local dev / Vercel Preview: leave unset (defaults to /)
# Production (Vercel): /nihonbenkyou/
VITE_APP_BASE_PATH=/
