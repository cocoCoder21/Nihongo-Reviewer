# ─── Database ─────────────────────────────────────────────────────
# Local dev: Postgres on localhost
# Production (Railway): Auto-injected by the PostgreSQL plugin — DO NOT set manually
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nihon_benkyou?schema=public"

# ─── JWT secrets ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
# JWT_SECRET and JWT_REFRESH_SECRET MUST be different values, 32+ chars each.
JWT_SECRET="change-me-to-a-random-secret-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-to-another-random-secret-at-least-32-chars"

# ─── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────
# Local dev: Vite dev server origin(s), comma-separated
# Production (Railway): https://angeliephl.dev
CORS_ORIGIN=http://localhost:5173
